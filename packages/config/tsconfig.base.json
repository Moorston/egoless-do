{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@egoless-do/core": ["../../packages/core/src/index.ts"],
      "@egoless-do/ui":   ["../../packages/ui/src/index.ts"]
    }
  }
}
