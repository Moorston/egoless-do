{
  "name": "egoless-do",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter mobile start",
    "mobile:android": "pnpm --filter mobile android",
    "mobile:ios": "pnpm --filter mobile ios",
    "web": "pnpm --filter web dev",
    "pb": "pocketbase\\pocketbase.exe serve --http=0.0.0.0:8090",
    "pb:setup": "powershell -ExecutionPolicy Bypass -File pocketbase\\setup.ps1",

    "build:mobile": "pnpm --filter mobile build",
    "build:web": "pnpm --filter web build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^8.57.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "^19.1.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "uuid": "^14.0.0"
  }
}
